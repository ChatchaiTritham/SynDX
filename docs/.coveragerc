[run]
# Coverage.py configuration for SynDX

# Source code to measure
source = syndx

# Omit specific files/patterns
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */syndx_env/*
    */venv/*
    */build/*
    */dist/*
    */.eggs/*
    setup.py
    # Demo code in __main__ blocks
    */__main__.py
    # Experimental and archival research prototypes outside the maintained test surface
    */syndx_temp/*
    */phase1_knowledge/archetype_generator.py
    */phase1_knowledge/nmf_discovery.py
    */phase1_knowledge/shap_importance.py
    */phase1_knowledge/titrate_formalizer.py
    */phase1_knowledge/xai_explorer.py
    */phase2_synthesis/nmf_extractor.py
    */phase2_synthesis/probabilistic_logic.py
    */phase2_synthesis/vae_model.py
    */phase2_synthesis/xai_driver.py
    */phase3_validation/evaluation_metrics.py
    */phase3_validation/statistical_metrics.py
    */phase3_validation/triate_classifier.py
    */utils/data_loader.py
    */utils/fhir_exporter.py
    */utils/profiler.py
    */utils/snomed_mapper.py

# Parallel mode for multiprocessing
parallel = False

# Branch coverage
branch = True

[report]
# Reporting options

omit =
    */syndx_temp/*
    */phase1_knowledge/archetype_generator.py
    */phase1_knowledge/nmf_discovery.py
    */phase1_knowledge/shap_importance.py
    */phase1_knowledge/titrate_formalizer.py
    */phase1_knowledge/xai_explorer.py
    */phase2_synthesis/nmf_extractor.py
    */phase2_synthesis/probabilistic_logic.py
    */phase2_synthesis/vae_model.py
    */phase2_synthesis/xai_driver.py
    */phase3_validation/evaluation_metrics.py
    */phase3_validation/statistical_metrics.py
    */phase3_validation/triate_classifier.py
    */utils/data_loader.py
    */utils/fhir_exporter.py
    */utils/profiler.py
    */utils/snomed_mapper.py

# Precision for coverage percentage
precision = 2

# Show missing lines
show_missing = True

# Skip covered files in report
skip_covered = False

# Skip empty files
skip_empty = True

# Sort output by name
sort = Name

# Exclude lines from coverage
exclude_lines =
    # Standard pragma
    pragma: no cover

    # Debug code
    def __repr__
    def __str__

    # Non-runnable code
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:

    # Abstract methods
    @abstractmethod
    @abc.abstractmethod
    raise NotImplementedError

    # Defensive programming
    raise AssertionError
    raise RuntimeError

    # Type checking
    pass
    \.\.\.

    # Logger debug statements
    logger\.debug

# Fail under minimum coverage
fail_under = 80.0

[html]
# HTML report options
directory = htmlcov
title = SynDX Test Coverage Report

[xml]
# XML report options (for CI/CD)
output = coverage.xml

[json]
# JSON report options
output = coverage.json
pretty_print = True
